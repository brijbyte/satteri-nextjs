{
  "$schema": "https://json.schemastore.org/package",
  "name": "satteri-nextjs",
  "version": "0.0.2",
  "description": "Next.js integration for satteri — Rust-native Markdown/MDX, compiled to React/RSC modules.",
  "homepage": "https://github.com/brijbyte/satteri-nextjs#readme",
  "bugs": {
    "url": "https://github.com/brijbyte/satteri-nextjs/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Brijbyte",
    "url": "https://github.com/brijbyte"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brijbyte/satteri-nextjs.git"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/index.js",
    "./loader": "./dist/loader.js",
    "./plugins": "./dist/plugins.js",
    "./mdx-components-fallback": "./dist/mdx-components-fallback.js"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dedupe:check": "pnpm dedupe --check",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "satteri": "^0.9.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "oxfmt": "0.57.0",
    "oxlint": "1.71.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18"
  },
  "packageManager": "pnpm@11.9.0"
}
