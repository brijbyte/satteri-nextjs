{
  "name": "satteri-nextjs",
  "version": "0.0.0",
  "description": "Next.js integration for satteri — Rust-native Markdown/MDX, compiled to React/RSC modules.",
  "type": "module",
  "license": "MIT",
  "author": "Brijesh Bittu",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./loader": "./dist/loader.js",
    "./mdx-components-fallback": "./dist/mdx-components-fallback.js"
  },
  "files": [
    "dist"
